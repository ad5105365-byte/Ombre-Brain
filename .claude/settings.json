{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session_breath.py\"",
            "timeout": 60,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/memory_recall.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
